generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  phone     String?
  password  String?
  image     String?
  role      String    @default("seller")
  provider  String    @default("credentials")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
  inquiries Inquiry[]
  vehicles  Vehicle[]
  orders    Order[]
  seafoodProducts SeafoodProduct[]
  reviews   ProductReview[]
}

model Vehicle {
  id            String            @id @default(cuid())
  title         String
  make          String
  model         String
  year          Int
  price         Float
  priceType     String
  mileage       Int?
  color         String?
  transmission  String?
  engine        String?
  fuelType      String?
  condition     String?
  description   String?
  images        String[]
  listingStatus String            @default("pending")
  approvedAt    DateTime?
  approvedBy    String?
  sellerId      String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  bookings      Booking[]
  inquiries     Inquiry[]
  seller        User              @relation(fields: [sellerId], references: [id])
  locations     VehicleLocation[]
}

model Inquiry {
  id        String   @id @default(cuid())
  vehicleId String
  userId    String
  message   String
  type      String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Booking {
  id              String     @id @default(cuid())
  vehicleId       String
  userId          String
  startDate       DateTime
  endDate         DateTime
  pickupTime      String
  returnTime      String
  duration        String
  pickupLocation  String
  totalPrice      Float
  status          String     @default("pending")
  agreementSigned Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id])
  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id])
  reminders       Reminder[]
}

model Reminder {
  id           String   @id @default(cuid())
  bookingId    String
  type         String
  scheduledFor DateTime
  sent         Boolean  @default(false)
  createdAt    DateTime @default(now())
  booking      Booking  @relation(fields: [bookingId], references: [id])
}

model VehicleLocation {
  id        String   @id @default(cuid())
  vehicleId String
  latitude  Float
  longitude Float
  speed     Float
  timestamp DateTime
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Quotation {
  id             String   @id @default(cuid())
  vehicleId      String
  basePrice      Float
  insuranceType  String
  insuranceCost  Float
  downPayment    Float
  duration       Int
  accessories    Float
  deliveryFee    Float
  totalPrice     Float
  monthlyPayment Float
  createdAt      DateTime @default(now())
}

model SeafoodCategory {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String?
  image       String?
  parentId    String?
  createdAt   DateTime        @default(now())
  products    SeafoodProduct[]
  parent      SeafoodCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    SeafoodCategory[] @relation("CategoryHierarchy")
}

model SeafoodProduct {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  description String?
  price        Float
  comparePrice Float?
  unit         String       @default("kg")
  categoryId   String
  vendorId    String
  vendor      User          @relation(fields: [vendorId], references: [id])
  category    SeafoodCategory @relation(fields: [categoryId], references: [id])
  images      String[]
  stock       Int           @default(0)
  minOrder    Int           @default(1)
  status     String        @default("active")
  featured   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  orderItems OrderItem[]
  variations ProductVariation[]
  reviews    ProductReview[]
}

model Order {
  id             String      @id @default(cuid())
  orderNumber    String      @unique
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  items          OrderItem[]
  subtotal       Float
  shippingFee    Float       @default(0)
  total          Float
  status         String      @default("pending")
  paymentMethod String?
  paymentStatus String      @default("pending")
  shippingName  String?
  shippingPhone String?
  shippingAddress String?
  shippingCity  String?
  notes         String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model OrderItem {
  id          String         @id @default(cuid())
  orderId     String
  order       Order          @relation(fields: [orderId], references: [id])
  productId   String
  product     SeafoodProduct @relation(fields: [productId], references: [id])
  quantity    Int
  price       Float
  variation  String? // Selected variation (e.g., "1kg", "500g", "Large")
  createdAt   DateTime      @default(now())
}

model ProductVariation {
  id           String         @id @default(cuid())
  productId    String
  product     SeafoodProduct @relation(fields: [productId], references: [id])
  name        String        // e.g., "1kg", "500g", "Large", "Medium"
  price       Float
  stock       Int          @default(0)
  sku         String?
  status     String       @default("active")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ProductReview {
  id          String         @id @default(cuid())
  productId   String
  product    SeafoodProduct @relation(fields: [productId], references: [id])
  userId     String
  user       User         @relation(fields: [userId], references: [id])
  rating     Int          // 1-5 stars
  title      String?
  content    String
  status     String       @default("pending") // pending, approved, rejected
  helpful   Int          @default(0)
  createdAt  DateTime      @default(now())
}
