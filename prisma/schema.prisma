generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  phone     String?
  password  String?
  image     String?
  role      String    @default("seller")
  provider  String    @default("credentials")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
  inquiries Inquiry[]
  vehicles  Vehicle[]
}

model Vehicle {
  id            String            @id @default(cuid())
  title         String
  make          String
  model         String
  year          Int
  price         Float
  priceType     String
  mileage       Int?
  color         String?
  transmission  String?
  engine        String?
  fuelType      String?
  condition     String?
  description   String?
  images        String[]
  listingStatus String            @default("pending")
  approvedAt    DateTime?
  approvedBy    String?
  sellerId      String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  bookings      Booking[]
  inquiries     Inquiry[]
  seller        User              @relation(fields: [sellerId], references: [id])
  locations     VehicleLocation[]
}

model Inquiry {
  id        String   @id @default(cuid())
  vehicleId String
  userId    String
  message   String
  type      String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Booking {
  id              String     @id @default(cuid())
  vehicleId       String
  userId          String
  startDate       DateTime
  endDate         DateTime
  pickupTime      String
  returnTime      String
  duration        String
  pickupLocation  String
  totalPrice      Float
  status          String     @default("pending")
  agreementSigned Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id])
  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id])
  reminders       Reminder[]
}

model Reminder {
  id           String   @id @default(cuid())
  bookingId    String
  type         String
  scheduledFor DateTime
  sent         Boolean  @default(false)
  createdAt    DateTime @default(now())
  booking      Booking  @relation(fields: [bookingId], references: [id])
}

model VehicleLocation {
  id        String   @id @default(cuid())
  vehicleId String
  latitude  Float
  longitude Float
  speed     Float
  timestamp DateTime
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Quotation {
  id             String   @id @default(cuid())
  vehicleId      String
  basePrice      Float
  insuranceType  String
  insuranceCost  Float
  downPayment    Float
  duration       Int
  accessories    Float
  deliveryFee    Float
  totalPrice     Float
  monthlyPayment Float
  createdAt      DateTime @default(now())
}
